# ===== Supabase =====
# Project URL and API keys: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# Postgres connection — use the Transaction pooler (port 6543), NOT the
# Direct connection (port 5432). lib/db/index.ts sets prepare:false which
# is only compatible with the pooler. The region in the host (e.g.
# aws-1-us-east-1) depends on where you created the project.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# ===== Anthropic (Claude) =====
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ===== App config =====
# Local dev: http://localhost:3000
# Production: set to your deployed URL (e.g. https://yourdomain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Cron security =====
# Generate with: openssl rand -base64 32
CRON_SECRET=run_openssl_rand_base64_32_to_generate_this

# ===== Encryption key for OAuth tokens =====
# Generate with: openssl rand -hex 32
# IMPORTANT: must be the SAME value in local and production, otherwise
# tokens encrypted in one environment cannot be decrypted in the other.
ENCRYPTION_KEY=64_character_hex_string_here

# Note: GitHub OAuth (Client ID / Client Secret) is configured directly
# in Supabase -> Authentication -> Providers -> GitHub. It is NOT read
# from env vars by this app.

# ===== Meta (Facebook + Instagram + Threads) =====
# Required for the /integrations Meta + Threads cards. Without these
# vars, the /api/integrations/meta/authorize endpoint returns 503 with
# a "Meta integration is not configured" message.
#
# Meta App ID + Secret:
#   Set up app at https://developers.facebook.com/apps. The app must
#   have these products added + reviewed:
#     - Facebook Login (for OAuth)
#     - Instagram Graph API (for IG publishing)
#     - Threads API (for Threads publishing — Sprint 7.5)
#   Required scopes (must be approved or running in development mode):
#     pages_show_list, pages_read_engagement, pages_manage_posts,
#     instagram_basic, instagram_content_publish, business_management,
#     threads_basic, threads_content_publish.
META_APP_ID=
META_APP_SECRET=
# Must match an "Valid OAuth Redirect URI" entry in the Meta app's
# Facebook Login settings. Use the absolute URL of /api/integrations/meta/callback.
META_REDIRECT_URL=http://localhost:3000/api/integrations/meta/callback

# ===== LinkedIn =====
# Required for the /integrations LinkedIn card + auto-publish to
# LinkedIn. Set up app at https://developer.linkedin.com/apps.
# Products needed (request access):
#   - Share on LinkedIn
#   - Sign In with LinkedIn using OpenID Connect
# OAuth scopes: openid profile email w_member_social
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
# Optional override. Falls back to <request origin>/api/integrations/
# linkedin/callback when unset (good for localhost dev where the
# origin varies per port).
LINKEDIN_REDIRECT_URL=

# ===== X (Twitter) =====
# Required for X auto-publish. X has NO per-user OAuth flow in Helm —
# all X publishing routes deploy-wide credentials (one X account per
# environment). For per-user X, the API requires OAuth 1.0a User
# Context which is out of scope for Sprint 7.5.
#
# To get these:
#   1. Apply for X Developer Account at https://developer.twitter.com
#   2. Free tier is read-only — Basic tier ($200/mo) is the minimum
#      that allows write/post operations.
#   3. Create a Project + App. Set "User authentication settings"
#      to "OAuth 1.0a", App permissions = "Read and write".
#   4. Generate Consumer Keys + Access Token & Secret (the access
#      token must be regenerated AFTER setting permissions to Write).
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
# Optional: bearer token for read-only app-context calls (rare).
X_BEARER_TOKEN=

# ===== HeyGen (Sprint 7.3 — queue placeholder) =====
# When BOTH of these are set, the /api/heygen/generate-video POST
# handler is allowed to process queued jobs. Until then, structured
# drafts that need video (reel, ugc) still get inserted into the
# heygen_jobs table with status='queued' — the worker just refuses
# to run until the flags flip.
HEYGEN_ENABLED=false
HEYGEN_API_KEY=

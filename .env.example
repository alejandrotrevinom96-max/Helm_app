# ===== Supabase =====
# Project URL and API keys: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# Postgres connection — use the Transaction pooler (port 6543), NOT the
# Direct connection (port 5432). lib/db/index.ts sets prepare:false which
# is only compatible with the pooler. The region in the host (e.g.
# aws-1-us-east-1) depends on where you created the project.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# ===== Anthropic (Claude) =====
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ===== App config =====
# Local dev: http://localhost:3000
# Production: set to your deployed URL (e.g. https://yourdomain.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Cron security =====
# Generate with: openssl rand -base64 32
CRON_SECRET=run_openssl_rand_base64_32_to_generate_this

# ===== Encryption key for OAuth tokens =====
# Generate with: openssl rand -hex 32
# IMPORTANT: must be the SAME value in local and production, otherwise
# tokens encrypted in one environment cannot be decrypted in the other.
ENCRYPTION_KEY=64_character_hex_string_here

# Note: GitHub OAuth (Client ID / Client Secret) is configured directly
# in Supabase -> Authentication -> Providers -> GitHub. It is NOT read
# from env vars by this app.
